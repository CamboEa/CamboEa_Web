# CamboEA - Environment Variables Example
# Copy this file to .env.local and fill in your values

# API Configuration
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_API_KEY=

# MetalpriceAPI (metals: XAU, XAG, XPT) - get key at https://metalpriceapi.com
METALPRICE_API_KEY=

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="CamboEA"

# --- News ingest (admin: ទាញយកព័ត៌មាន AI) ---
# Required for POST /api/admin/news/ingest. Key from https://playground.sea-lion.ai/ (API Key Manager)
SEA_LION_API_KEY=
# Optional overrides (defaults: https://api.sea-lion.ai/v1 and aisingapore/Gemma-SEA-LION-v4-27B-IT)
# SEA_LION_BASE_URL=https://api.sea-lion.ai/v1
# SEA_LION_MODEL=aisingapore/Gemma-SEA-LION-v4-27B-IT

# Optional: replace default RSS sources (JSON array). Each entry: id, label, feedUrl, category ("forex"|"crypto"), optional allowedArticleHosts (string[])
# NEWS_INGEST_SOURCES_JSON=[{"id":"coindesk-rss","label":"CoinDesk","feedUrl":"https://www.coindesk.com/arc/outboundfeeds/rss/","allowedArticleHosts":["coindesk.com"],"category":"crypto"}]

# --- Supabase (admin + public news from DB) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Optional: news publish notifications ---
# TELEGRAM_BOT=
# TELEGRAM_CHANNEL_ID=
# FACEBOOK_PAGE_ID=
# FACEBOOK_PAGE_ACCESS_TOKEN=
