# CamboEA - Environment Variables Example
# Copy this file to .env.local and fill in your values

# API Configuration
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_API_KEY=

# MetalpriceAPI (metals: XAU, XAG, XPT) - get key at https://metalpriceapi.com
METALPRICE_API_KEY=

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="CamboEA"
